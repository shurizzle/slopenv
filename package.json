{
  "name": "slopenv",
  "version": "1.0.3",
  "description": "Sensible environment variable loading for monorepos.",
  "keywords": [
    "dotenv",
    "env",
    "monorepo",
    "config",
    "precedence",
    "environment-variables"
  ],
  "homepage": "https://github.com/shurizzle/slopenv#readme",
  "bugs": {
    "url": "https://github.com/shurizzle/slopenv/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shurizzle/slopenv.git"
  },
  "license": "MIT",
  "author": "shurizzle <me@shurizzle.dev>",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist"
  ],
  "bin": {
    "slopenv": "./dist/slopenv.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "test": "node --import @oxc-node/core/register --test test/**/*.test.ts",
    "test:watch": "node --import @oxc-node/core/register --test --watch test/**/*.test.ts",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:ci": "npm run lint -- --deny-warnings",
    "typecheck": "tsc --noEmit",
    "check": "concurrently --kill-others-on-fail npm:format:check npm:lint npm:typecheck",
    "check:ci": "concurrently --kill-others-on-fail npm:format:check npm:lint:ci npm:typecheck",
    "build": "tsdown --tsconfig tsconfig.build.json --config-loader unrun",
    "prepare": "npm run build",
    "dev": "tsdown --tsconfig tsconfig.app.json --config-loader unrun -w"
  },
  "devDependencies": {
    "@oxc-node/core": "^0.0.35",
    "@types/dotenv": "^6.1.1",
    "concurrently": "^9.2.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.0",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  }
}
